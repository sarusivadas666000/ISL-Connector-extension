{
  "manifest_version": 3,
  "name": "ISL-Connect SidePanel",
  "version": "1.1",
  "description": "Two-way Indian Sign Language overlay side panel tool.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Open ISL-Connect"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  }
}