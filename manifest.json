{
  "manifest_version": 3,
  "name": "ISL-Sync Overlay",
  "version": "1.0",
  "description": "Two-way Indian Sign Language overlay tool.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": { 
    "default_popup": "popup.html" 
  },
 "content_scripts": [
    {
      "matches": ["https://meet.google.com/*", "https://*.zoom.us/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}